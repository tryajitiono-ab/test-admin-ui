{
  "name": "vite-project",
  "description": "A full-set React template for Extend App UI, along with targeting multiple Extend apps capability",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write src/**/*",
    "format:swaggers": "prettier --write swaggers/**/*",
    "patch:swaggers": "node scripts/patch-tags.mjs",
    "cg:prettify": "prettier --write --no-error-on-unmatched-pattern src/codegen/**/*",
    "cg:generate": "accelbyte-codegen generate-code --config swaggers.json --swaggersOutput swaggers --output src/codegen",
    "cg:download": "accelbyte-codegen download-swaggers --config swaggers.json --swaggersOutput swaggers && npm run format:swaggers && npm run patch:swaggers",
    "cg:clean-and-generate": "rimraf src/codegen && npm run cg:generate && npm run cg:prettify",
    "codegen": "npm run cg:download && npm run cg:clean-and-generate"
  },
  "dependencies": {
    "@accelbyte/sdk": "0.0.0-dev-20260408102041",
    "@accelbyte/sdk-extend-app-ui": "0.0.0-dev-20260408102041",
    "@accelbyte/sdk-iam": "0.0.0-dev-20260408102041",
    "@accelbyte/validator": "0.2.30",
    "@module-federation/vite": "1.11.1",
    "@tanstack/react-query": "5.90.21",
    "antd": "6.3.1",
    "axios": "1.13.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "7.13.1"
  },
  "devDependencies": {
    "@accelbyte/codegen": "0.0.0-dev-20260408102041",
    "@eslint/js": "9.39.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/http-proxy": "1.17.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "http-proxy": "1.18.1",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "7.1.7",
    "zod": "3.25.76"
  },
  "overrides": {
    "axios": "1.13.6",
    "zod": "3.25.76"
  }
}
